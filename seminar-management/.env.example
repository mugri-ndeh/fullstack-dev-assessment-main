# Copy to .env and fill in the secrets. Compose reads this file for the app
# container; DATABASE_URL/SMTP_* are overridden in-network by docker-compose.yml.

# --- Database ---------------------------------------------------------------
# Used when running the app or Prisma CLI directly on the host.
DATABASE_URL=postgresql://seminar:seminar_dev_pw@localhost:5432/seminar?schema=public
POSTGRES_PASSWORD=seminar_dev_pw

# --- Auth -------------------------------------------------------------------
# iron-session cookie encryption key — MUST be at least 32 chars.
# Generate one: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-32+-char-string!!

# --- AI (trainer matching) ---------------------------------------------------
# OpenRouter (https://openrouter.ai/keys). OpenAI-compatible API; the model is
# configurable so cost/quality can be tuned without code changes.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# --- Email (Mailhog in dev) ---------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM="Seminar Management <noreply@seminar.local>"
